{
  "name": "WebHub_Desktop",
  "version": "3.1.0",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/FailouN/WebHub_Desktop.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.WebHub.Desktop",
    "productName": "WebHub_Desktop",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "FailouN",
        "repo": "WebHub_Desktop"
      }
    ],
    "extraResources": [
      {
        "from": "user_data/",
        "to": "user_data/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "latest",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "@ghostery/adblocker-electron": "^2.14.1",
    "@shiguredo/rnnoise-wasm": "^2025.1.5",
    "cross-fetch": "^4.1.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "https-proxy-agent": "^9.0.0",
    "mic": "^2.1.2",
    "node-record-lpcm16": "^1.0.1"
  }
}
