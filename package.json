{
  "name": "WebHub_Desktop",
  "version": "2.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.WebHub.Desktop",
    "productName": "WebHub_Desktop",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "user_data/",
        "to": "user_data/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    }
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.34.0",
    "@ghostery/adblocker-electron": "^2.14.1",
    "cross-fetch": "^4.1.0",
    "https-proxy-agent": "^9.0.0"
  }
}
